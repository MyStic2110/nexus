        "1774719815406": {
            "matchId": 149618,
            "commType": "commentary",
            "commText": "<b>Successful 200-plus chases for RCB in IPL </b> <br>228 vs LSG, Lucknow, 2025 <br>204 vs KXIP, Bengaluru, 2010 <br>202 vs SRH, Bengaluru, 2026*  <br>201 vs GT, Ahmedabad, 2024 <br> <br>- This is also the second-highest successful chase against SRH after KXIP gunned down 206 runs at Hyderabad in 2014.  <br> <br><b>Least overs taken to complete a 200-plus chase in IPL</b> <br>15.4 - RCB vs SRH, Bengaluru, 2026* <br>15.5 - RR vs GT, Jaipur, 2025 <br>16.0 - RCB vs GT, Ahmedabad, 2024 <br>16.3 - MI vs RCB, Wankhede, 2023 <br>17.3 - DC vs GL, Delhi, 2017 <br> <br><b>Virat Kohli in his first game:</b>  <br>IPL 2025: 59* (36) vs KKR, Kolkata <br>IPL 2026: 69* (38) vs SRH, Bengaluru <br> <br><b>Virat Kohli\u2019s last 5 scores vs SRH </b> <br>100 (63) <br>42 (20) <br>51 (43) <br>43 (25)  <br>69* (38) \u2014 today  <br> <br><b>Most runs in IPL chases </b> <br>4027 - Virat Kohli*  <br>3285 - David Warner  <br>3238 - Rohit Sharma <br>2843 - Shikhar Dhawan <br>2832 - Robin Uthappa",
            "inningsId": 2,
            "event": [
                "none",
                "all"
            ],
            "teamName": "RCB",
            "timestamp": 1774719815406,
            "overSeparator": null,
