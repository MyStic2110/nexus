# Nexus IPL 2026 - Configuration Template
APP_NAME=ipl-nexus-2026
ENV=production
LOG_LEVEL=INFO

# Server Config
HOST=127.0.0.1
PORT=8000

# MongoDB (Update with your Atlas URI)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/database_name
DB_NAME=ipl_game

# Redis (Update with your URL)
REDIS_URL=redis://localhost:6379/0

# Google OAuth2 Credentials
# Get this from Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your_client_id_here

# Cricket API Mock/Real
# (Optional for automated polling)
CRICKET_API_BASE=https://api.cricketapi.com/v1
CRICKET_API_KEY=your_cricket_api_key

# Scoring & Governance
POLL_INTERVAL_SECONDS=5
SCORING_EXACT=10
SCORING_NEAR=5
MAX_PREDICTIONS_PER_USER=24
